PROJECT_NAME=amorae
PROJECT_DOMAIN=amorae.ai
PROJECT_REPO=amorae-web
# amorae_db is a SEPARATE database on the SAME Patroni cluster as v2
# (decision #18). YRAL/v2 services hold no credentials to it — Level-2
# isolation is logical, not physical.
POSTGRES_DB=amorae_db
PATRONI_SCOPE=agent-cluster
OVERLAY_NETWORK=agent-db-internal
IMAGE_REPO=ghcr.io/dolr-ai/amorae-web
WITH_DATABASE=false
