# amorae-web deploys onto the SAME v2 cluster (rishi-4/5) per decision #18.
# Edge Caddy on rishi-1/2/3 routes amorae.ai → rishi-4/5 via amorae's OWN
# per-service .caddy site. NEVER touch chat-ai routes on 1/2/3 (Rule 7).
# IPs live in GitHub Secrets (RISHI_4_PUBLIC_IPV4, RISHI_5_PUBLIC_IPV4).

APP_SERVERS=rishi-4,rishi-5
CADDY_HOSTS=rishi-1,rishi-2,rishi-3
DB_SERVERS=rishi-4,rishi-5,rishi-6

DEPLOY_USER=deploy
SSH_KEY_PATH=~/.ssh/rishi-hetzner-ci-key
