# amorae deploys onto the SAME v2 cluster (rishi-4/5) per decision #18, as
# the Swarm service `amorae_web` (stack `amorae`). Deploy = docker service
# update via the 3 swarm managers (rishi-4/5/6), SSH user rishi-deploy.
#
# Caddy (L1 edge on rishi-1/2/3 + L2 swarm-side) is OWNED BY SESSION 6 via
# the Swarm CONFIGS pattern — amorae ships NO .caddy file. NEVER touch
# chat-ai routes on 1/2/3 (Rule 7).

APP_SERVERS=rishi-4,rishi-5
DB_SERVERS=rishi-4,rishi-5,rishi-6

DEPLOY_USER=rishi-deploy
SSH_KEY_PATH=~/.ssh/rishi-hetzner-ci-key
