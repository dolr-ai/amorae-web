# amorae-web — local dev env. Copy to .env.local and fill in.

# amorae_db ONLY. No yral_agent_db credential ever lives here (Level-2).
DATABASE_URL=postgresql://amorae:amorae@localhost:5432/amorae_db

# LLM — reuse the SAME OpenRouter key/model as v2's user_chat_main_nsfw.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# v2 bridges (auth handoff + context read). Server-to-server secret.
V2_BASE_URL=http://localhost:8001
V2_WEB_SHARED_SECRET=

# Cookies — set false for plain-HTTP local dev.
COOKIE_SECURE=false

# Geo-gate: comma-separated ISO country codes to BLOCK. Empty = OPEN.
GEO_BLOCKED_COUNTRIES=

# Skeleton-only: let Continue(18+) open an anon session with no ticket,
# so you can test end-to-end before v2's handoff endpoint exists.
# MUST be false in production.
DEV_ALLOW_ANON=true

ENVIRONMENT=development
DEBUG=true
